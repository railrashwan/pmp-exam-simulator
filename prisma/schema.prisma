generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Question {
  id             Int      @id @default(autoincrement())
  domain         String
  questionTextEn String
  questionTextAr String
  optionAEn      String
  optionAAr      String
  optionBEn      String
  optionBAr      String
  optionCEn      String
  optionCAr      String
  optionDEn      String
  optionDAr      String
  correctAnswer      String
  explanationEn      String
  explanationAr      String
  examSet            String   @default("pmp")
  globalBank         Boolean  @default(false)
  wrongExplanationEn String?
  wrongExplanationAr String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  spacedRepCards     SpacedRepCard[]
}

model ExamAttempt {
  id              Int             @id @default(autoincrement())
  examSet         String
  takenAt         DateTime        @default(now())
  totalQuestions  Int
  correctAnswers  Int
  score           Float
  passed          Boolean
  domainBreakdown String          // JSON string (legacy — kept for compat)
  results         AttemptResult[]
  domainResults   DomainResult[]
}

model AttemptResult {
  id             Int         @id @default(autoincrement())
  attemptId      Int
  attempt        ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId     Int
  selectedAnswer String?
  isCorrect      Boolean
}

model DomainResult {
  id        Int         @id @default(autoincrement())
  attemptId Int
  attempt   ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  domain    String
  correct   Int
  total     Int
}

model SpacedRepCard {
  id           Int      @id @default(autoincrement())
  questionId   Int
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  interval     Int      @default(1)       // days until next review
  ease         Float    @default(2.5)     // ease factor (SM-2)
  nextReview   DateTime @default(now())   // when this card is due
  reviewCount  Int      @default(0)       // total reviews
  lastRating   String?                    // easy/hard/forgot
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  reviewLogs   ReviewLog[]
}

model ReviewLog {
  id              Int            @id @default(autoincrement())
  cardId          Int
  card            SpacedRepCard  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  ratedAt         DateTime       @default(now())
  rating          String         // easy/hard/forgot
  intervalAfter   Int            // what interval was set after this review
}
