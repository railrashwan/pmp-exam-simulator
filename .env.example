# Turso (cloud SQLite) — required for production
# Get these from: https://app.turso.tech
DATABASE_URL="libsql://your-database-name.turso.io"
DATABASE_AUTH_TOKEN="your-auth-token"

# Admin panel password — leave unset to disable auth (dev mode)
ADMIN_PASSWORD="your-admin-password"

# For local development, leave DATABASE_URL unset to use the local dev.db file
